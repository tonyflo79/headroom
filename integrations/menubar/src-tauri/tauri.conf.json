{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Headroom",
  "version": "0.4.0",
  "identifier": "dev.headroom.menubar",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; frame-src 'none'; form-action 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "externalBin": [
      "binaries/headroom-engine"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Self-contained desktop dashboard for AI account headroom",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDNUQyRjZDQkM0RjEwODgKUldTSUVFKzhiQzlkUENINmZBK04vM080dDM0d0xjVW4xUGJ3RU5xUE9Ba0RJaFVLL2dqbUZWQ1gK",
      "endpoints": [
        "https://github.com/tonyflo79/headroom/releases/latest/download/latest.json"
      ]
    }
  }
}
