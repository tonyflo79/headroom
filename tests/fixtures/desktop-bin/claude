#!/bin/sh
set -eu

if [ "${1:-}" = "--version" ]; then
  echo "2.1.211 (Claude Code)"
  exit 0
fi

if [ "${1:-}" = "auth" ] && [ "${2:-}" = "--help" ]; then
  echo "login  Sign in to your Anthropic account"
  exit 0
fi

if [ "${1:-}" = "auth" ] && [ "${2:-}" = "login" ]; then
  sleep "${HEADROOM_FAKE_LOGIN_DELAY:-0}"
  mkdir -p "${CLAUDE_CONFIG_DIR}"
  printf '%s\n' '{"claudeAiOauth":{"accessToken":"fixture-token"}}' > "${CLAUDE_CONFIG_DIR}/.credentials.json"
  exit "${HEADROOM_FAKE_LOGIN_EXIT:-0}"
fi

if [ "${1:-}" = "auth" ] && [ "${2:-}" = "status" ]; then
  echo '{"loggedIn":true,"email":"fixture@example.test","orgId":"fixture-org","subscriptionType":"pro"}'
  exit 0
fi

exit 1
